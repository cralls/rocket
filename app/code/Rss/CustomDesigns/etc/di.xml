    <virtualType name="Rss\CustomDesigns\Model\ResourceModel\CustomDesign\Collection"
                 type="Rss\CustomDesigns\Ui\Component\DataProvider\SearchResult\Items">
        <arguments>
            <argument name="mainTable" xsi:type="string">rss_custom_designs</argument>
            <argument name="resourceModel" xsi:type="string">Rss\CustomDesigns\Model\ResourceModel\CustomDesign</argument>
        </arguments>
    </virtualType>

    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="rss_custom_designs_listing_data_source"
                      xsi:type="string">Rss\CustomDesigns\Model\ResourceModel\CustomDesign\Collection</item>
            </argument>
        </arguments>
    </type>
    
    <virtualType name="Rss\CustomDesigns\Model\ResourceModel\ProductionRequest\Collection"
