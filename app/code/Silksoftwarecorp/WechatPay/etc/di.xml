<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Silksoftwarecorp\WechatPay\Model\Logger\Handler\Debug">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Silksoftwarecorp\WechatPay\Model\Logger\Handler\Error">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Silksoftwarecorp\WechatPay\Model\Logger">
        <arguments>
            <argument name="name" xsi:type="string">wechatPayLogHandler</argument>
            <argument name="handlers"  xsi:type="array">
                <item name="debug" xsi:type="object">Silksoftwarecorp\WechatPay\Model\Logger\Handler\Debug</item>
                <item name="error" xsi:type="object">Silksoftwarecorp\WechatPay\Model\Logger\Handler\Error</item>
            </argument>
        </arguments>
    </type>

	<preference for="Silksoftwarecorp\WechatPay\Api\NotifyInterface" type="Silksoftwarecorp\WechatPay\Model\Notify"/>

</config>
