            </argument>
        </arguments>
    </type>
    
    <type name="Rss\CustomDesigns\Ui\DataProvider\CustomDesign\FormDataProvider">
    	<arguments>
        	<argument name="name" xsi:type="string">rss_custom_designs_form_data_source</argument>
        	<argument name="primaryFieldName" xsi:type="string">entity_id</argument>
        	<argument name="requestFieldName" xsi:type="string">entity_id</argument>
    	</arguments>
	</type>
	
	<virtualType name="Rss\CustomDesigns\Model\ResourceModel\Pattern\Collection"
             type="Rss\CustomDesigns\Ui\Component\DataProvider\SearchResult\Items">
	    <arguments>
	        <argument name="mainTable" xsi:type="string">rss_custom_designs_patterns</argument>
	        <argument name="resourceModel" xsi:type="string">
