<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- Account affiliate -->
    <route url="/V1/affiliate/account/addandupdate" method="POST">
        <service class="MW\Affiliate\Api\Account\AccountRepositoryInterface" method="save"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>
    <route url="/V1/affiliate/account/delete" method="POST">
        <service class="MW\Affiliate\Api\Account\AccountRepositoryInterface" method="delete"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>

    <!-- Commission -->
    <route url="/V1/affiliate/commission/addandupdate" method="POST">
        <service class="MW\Affiliate\Api\Commission\CommissionRepositoryInterface" method="save"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>
    <route url="/V1/affiliate/commission/delete" method="POST">
        <service class="MW\Affiliate\Api\Commission\CommissionRepositoryInterface" method="delete"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>

    <!-- Transaction -->
    <route url="/V1/affiliate/transaction/addandupdate" method="POST">
        <service class="MW\Affiliate\Api\Transaction\TransactionRepositoryInterface" method="save"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>
    <route url="/V1/affiliate/transaction/delete" method="POST">
        <service class="MW\Affiliate\Api\Transaction\TransactionRepositoryInterface" method="delete"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>


    <!-- Program -->
    <route url="/V1/affiliate/program/addandupdate" method="POST">
        <service class="MW\Affiliate\Api\Program\ProgramRepositoryInterface" method="save"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>
    <route url="/V1/affiliate/program/delete" method="POST">
        <service class="MW\Affiliate\Api\Program\ProgramRepositoryInterface" method="delete"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>

    <!-- Banner -->
    <route url="/V1/affiliate/banner/addandupdate" method="POST">
        <service class="MW\Affiliate\Api\Banner\BannerRepositoryInterface" method="save"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>
    <route url="/V1/affiliate/banner/delete" method="POST">
        <service class="MW\Affiliate\Api\Banner\BannerRepositoryInterface" method="delete"/>
        <resources>
            <resource ref="MW_Affiliate::affiliate" />
        </resources>
    </route>

</routes>