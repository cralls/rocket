$paymentInfo = $block->getPaymentInfo();
$order = $block->getOrder();
$helper = $this->helper("Silksoftwarecorp\WechatPay\Helper\Data");
?>
<div class="wechatpay-pay">
<?php if($paymentInfo['trade_type'] == 'NATIVE'): ?>
    <p><?php echo __("Your order has been received. Order No.: %1", $order->getIncrementId()); ?></p>
    <p><?php echo __('Grand Total:') ?> <?php echo $helper->formatPrice($order->getBaseGrandTotal(), $order->getBaseCurrencyCode()); ?><?php if($order->getBaseCurrencyCode() != $order->getOrderCurrencyCode()){echo "(".$helper->formatPrice($order->getGrandTotal(), $order->getOrderCurrencyCode()).")";} ?></p>
    <p><?php echo __("Please use wechat to scan the QR Code to complete the payment.") ?></p>
    <p><img alt="QR Checkout" src="<?php echo $block->getUrl('wechatpay/checkout/qrcode', array('data' => urlencode($paymentInfo['code_url']))); ?>" style="width:150px;height:150px;"/></p>

<script type="text/javascript">
require([
    'jquery'
], function($){

        function checkStatus(){
            $.get(
                "<?php echo $block->getUrl('wechatpay/checkout/status') ?>",
                {id : "<?php echo $order->getId(); ?>"},
                function(response){
                    if(response == 'success'){
                        window.location.href = '<?php echo $block->getUrl('wechatpay/checkout/success'); ?>'
                    }
                }
            );
        }


    var checkPay = setInterval(checkStatus,3000);
});
</script>
<?php elseif($paymentInfo['trade_type'] == 'MWEB'): ?>
<?php $h5RedirectUrl = $paymentInfo['mweb_url']; ?>
<script type="text/javascript">
window.location.replace('<?php echo $h5RedirectUrl; ?>');
</script>
<?php elseif($paymentInfo['trade_type'] == 'JSAPI'): ?>
<?php
$jsApiParameters = $paymentInfo['js_api_parameters'];
$editAddress = $paymentInfo['edit_address'];
?>
<script type="text/javascript">
	//调用微信JS api 支付
	function jsApiCall()
	{
		WeixinJSBridge.invoke(
			'getBrandWCPayRequest',
			<?php echo $jsApiParameters; ?>,
			function(res){
				/*WeixinJSBridge.log(res.err_msg);
				alert(res.err_code+res.err_desc+res.err_msg);*/
                if(res.err_msg == "get_brand_wcpay_request:ok" ){
                    window.location.href="<?php echo $block->getUrl('wechatpay/checkout/success') ?>";
                }
			}
		);
	}

	function callpay()
	{
		if (typeof WeixinJSBridge == "undefined"){
		    if( document.addEventListener ){
		        document.addEventListener('WeixinJSBridgeReady', jsApiCall, false);
		    }else if (document.attachEvent){
		        document.attachEvent('WeixinJSBridgeReady', jsApiCall);
		        document.attachEvent('onWeixinJSBridgeReady', jsApiCall);
		    }
		}else{
		    jsApiCall();
		}
	}
</script>
