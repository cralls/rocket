        <field name="length_type">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Averun\SizeChart\Model\Attribute\Source\LengthTypes</item>
                <item name="config" xsi:type="array">
                    <item name="label" translate="true" xsi:type="string">Calculate like as</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="sortOrder" xsi:type="string">200</item>
                    <item name="source" xsi:type="string">main_fieldset</item>
                </item>
            </argument>
        </field>
    </fieldset>
</form>