<?xml version="1.0"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <virtualType name="Meetanshi\Alipay\Model\ConfigProvider" type="Magento\Payment\Model\CcGenericConfigProvider">
        <arguments>
            <argument name="methodCodes" xsi:type="array">
                <item name="alipay" xsi:type="const">Meetanshi\Alipay\Model\Payment::CODE</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="Magento\Checkout\Model\CompositeConfigProvider">
        <arguments>
            <argument name="configProviders" xsi:type="array">
                <item name="alipay_config_provider" xsi:type="object">Meetanshi\Alipay\Model\AlipayConfigProvider</item>
            </argument>
        </arguments>
    </type>

    <virtualType name="MeetanshiAlipayIframeCcConfigProvider" type="Magento\Payment\Model\IframeConfigProvider">
        <arguments>
            <argument name="methodCode" xsi:type="const">Meetanshi\Alipay\Model\Payment::CODE</argument>
        </arguments>
    </virtualType>
</config>
