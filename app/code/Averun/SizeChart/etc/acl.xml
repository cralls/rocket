<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::content">
                    <resource id="Averun_SizeChart::sizechart" title="Size Chart" translate="title" sortOrder="1">
                        <resource id="Averun_SizeChart::type" title="Type" translate="title" sortOrder="10" />
                        <resource id="Averun_SizeChart::category" title="Category" translate="title" sortOrder="20" />
                        <resource id="Averun_SizeChart::dimension" title="Dimension" translate="title" sortOrder="30" />
                        <resource id="Averun_SizeChart::chart" title="Chart" translate="title" sortOrder="40" />
                        <resource id="Averun_SizeChart::import" title="Import" translate="title" sortOrder="50" />
                        <resource id="Averun_SizeChart::config_sizechart" title="Config" translate="title" sortOrder="60" />
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
