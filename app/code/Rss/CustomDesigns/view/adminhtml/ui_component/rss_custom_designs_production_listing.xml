<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">rss_custom_designs_production_listing.rss_production_request_listing_data_source</item>
            <item name="deps" xsi:type="string">rss_custom_designs_production_listing.rss_production_request_listing_data_source</item>
        </item>
        <item name="spinner" xsi:type="string">production_columns</item>
        <item name="buttons" xsi:type="array">
    	<item name="add" xsi:type="array">
        	<item name="name" xsi:type="string">add</item>
        	<item name="label" xsi:type="string" translate="true">New Production Request</item>
        	<item name="class" xsi:type="string">primary</item>
        	<!-- go to your admin form/new action -->
        	<item name="url" xsi:type="string">customdesigns/production/edit</item>
        	<!-- optional ordering; lower shows farther left -->
        	<item name="sortOrder" xsi:type="number">10</item>
    	</item>
		</item>
        
    </argument>

    <dataSource name="rss_production_request_listing_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider</argument>
            <argument name="name" xsi:type="string">rss_production_request_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">entity_id</argument>
            <argument name="requestFieldName" xsi:type="string">entity_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">entity_id</item>
                    </item>
                </item>
            </argument>
        </argument>
    </dataSource>

    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="production_columns">

        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <sorting>desc</sorting>
                <label>ID</label>
            </settings>
        </column>

        <column name="customer_name">
            <settings>
                <filter>text</filter>
                <label>Customer</label>
            </settings>
        </column>

        <column name="sales_name">
            <settings>
                <filter>text</filter>
                <label>Sales</label>
            </settings>
        </column>

        <column name="is_vip">
            <settings>
                <filter>select</filter>
                <label>VIP</label>
                <options>
                    <option name="no" xsi:type="array">
                        <item name="value" xsi:type="number">0</item>
                        <item name="label" xsi:type="string">No</item>
                    </option>
                    <option name="yes" xsi:type="array">
                        <item name="value" xsi:type="number">1</item>
                        <item name="label" xsi:type="string">Yes</item>
                    </option>
                </options>
            </settings>
        </column>

        <column name="delivery_request_date">
            <settings>
                <filter>dateRange</filter>
                <label>Delivery Date</label>
            </settings>
        </column>

        <column name="fit_and_sizing">
            <settings>
                <filter>select</filter>
                <label>Fit &amp; Sizing</label>
            </settings>
        </column>

        <column name="shipping_method">
            <settings>
                <filter>select</filter>
                <label>Shipping</label>
            </settings>
        </column>

        <column name="shipment_type">
            <settings>
                <filter>select</filter>
                <label>Shipment Type</label>
            </settings>
        </column>

        <column name="status">
            <settings>
                <filter>select</filter>
                <label>Status</label>
            </settings>
        </column>

        <column name="created_at">
            <settings>
                <filter>dateRange</filter>
                <label>Created</label>
            </settings>
        </column>

        <actionsColumn name="actions" class="Rss\CustomDesigns\Ui\Component\Listing\Column\ProductionActions">
    		<settings>
        		<indexField>entity_id</indexField>
    		</settings>
		</actionsColumn>


    </columns>
</listing>
