<script>
    require([
        "jquery",
        'mage/template',
        'text!Webkul_Rmasystem/template/preview.html',
        'Magento_Ui/js/modal/modal',
        'mage/calendar',
    ], function($, mageTemplate, thumbnailPreviewTemplate){
        'use strict';
        var dataForm = $('#edit_form');
        dataForm.mage('validation', {});

        $('#save').on('click', function() {
            if (dataForm.valid()!=false) {
                $(this).attr('disabled','disabled');
                $('#edit_form').submit();
            }
        });

        $('.wk_rma_add_images').on('click',function(){
            var self = $(this);
            var modalHtml = mageTemplate(
                thumbnailPreviewTemplate,
                {
                    src: self.attr('src'), alt: self.attr('alt'), link: "<?= /* @noEscape */ $block->getUrl('rmasystem/allrma/downloadfile/', ['_secure' => $block->getRequest()->isSecure(), 'id'=> $rma->getId()]) ?>"+'file_name/'+self.attr('alt'),
                    linkText: $.mage.__('Download')
                }
            );
            var previewPopup = $('<div/>').html(modalHtml);
            previewPopup.modal({
                title: $.mage.__('RMA Image'),
                innerScroll: true,
                modalClass: '_image-box',
                buttons: []}).trigger('openModal');
        });
    });
</script>
