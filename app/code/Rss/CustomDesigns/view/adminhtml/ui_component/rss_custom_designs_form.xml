<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Ui/etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">rss_custom_designs_form.rss_custom_designs_form_data_source</item>
            <item name="deps" xsi:type="string">rss_custom_designs_form.rss_custom_designs_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Custom Design Request</item>
        <item name="config" xsi:type="array">
            <item name="dataScope" xsi:type="string">data</item>
            <item name="namespace" xsi:type="string">rss_custom_designs_form</item>
        </item>
    </argument>
    
    <dataSource name="rss_custom_designs_form_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">
                Rss\CustomDesigns\Ui\DataProvider\CustomDesign\FormDataProvider
            </argument>
            <argument name="name" xsi:type="string">
                rss_custom_designs_form_data_source
            </argument>
            <argument name="primaryFieldName" xsi:type="string">entity_id</argument>
            <argument name="requestFieldName" xsi:type="string">entity_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                </item>
            </argument>
        </argument>
    </dataSource>
    
    
    <dataSource name="orderimport_upload_form_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">VNS\OrderImport\Model\DataProvider</argument>
            <argument name="name" xsi:type="string">orderimport_upload_form_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">entity_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                </item>
            </argument>
        </argument>
    </dataSource>
    
    <form>
        <fieldset name="general">
            <field name="sales_person_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string">Sales Person's Name</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="validation" xsi:type="array"><item name="required-entry" xsi:type="boolean">true</item></item>
                </item>
            </argument>
        </field>
        </fieldset>
    </form>
</listing>


