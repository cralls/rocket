<script type="text/javascript">
    require([
        'jquery',
        'mage/mage'
    ], function($){

        var dataForm = $('#save_rma_form');
        dataForm.mage('validation', {});
            
        $('body').on('click','#wk_rma_button_submit', function() {
            if (dataForm.valid()!=false) {
                $(this).attr('disabled','disabled');
            }
        });
        var rma_prod = [];
        $('body').on('click','.wk_rma_pro_check',function(){
            let rma_product_type = $(this).data('product_type');
            if($(this).is(":checked")){
                rma_prod.push(rma_product_type);
            }else{
                var i = rma_prod.indexOf(rma_product_type);
                if(i != -1) {
                    rma_prod.splice(i, 1);
                }
            }
            if(rma_prod.indexOf("simple") > -1 ||  rma_prod.indexOf("configurable") > -1) {
                $('.wk-delivery').css('display','block');
            } else {
                $('.wk-delivery').css('display','none');
            }
        });
       
        $('body').on('click','#all_select',function(){
            if($(this).is(":checked")){
                $('.wk_rma_pro_check').each(function(){
                   var product_type =  $(this).data('product_type');
                   rma_prod.push(product_type);
                });
                if(rma_prod.indexOf("simple") > -1 ||  rma_prod.indexOf("configurable") > -1) {
                    $('.wk-delivery').css('display','block');
                } else {
                    $('.wk-delivery').css('display','none');
                }
            } else {
                rma_prod = [];
                $('.wk-delivery').css('display','block');
            }
        });

    });
</script>
