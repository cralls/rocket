	        </argument>
	    </arguments>
	</virtualType>
	
	<type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
	    <arguments>
	        <argument name="collections" xsi:type="array">
	            <item name="rss_custom_designs_patterns_listing_data_source"
	                  xsi:type="string">
	                Rss\CustomDesigns\Model\ResourceModel\Pattern\Collection
