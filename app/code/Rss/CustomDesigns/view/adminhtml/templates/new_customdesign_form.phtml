/** @var \Rss\CustomDesigns\Block\Adminhtml\Request\Edit\Form $block */

$model = $block->getModel();
$data  = $model ? $model->getData() : [];

function e($value) {
    return htmlspecialchars((string)$value, ENT_QUOTES);
}

function checked($name, $value, $data) {
    return (($data[$name] ?? '') === $value) ? 'checked' : '';
}

function selected($name, $value, $data) {
    return (($data[$name] ?? '') === $value) ? 'selected' : '';
}
