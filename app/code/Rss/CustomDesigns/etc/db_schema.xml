<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="rss_custom_designs" resource="default" engine="innodb" comment="Custom Design Requests">
        <column xsi:type="int" name="entity_id" nullable="false" identity="true" unsigned="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="request_type" nullable="false" length="16" comment="New/Updated"/>
        <column xsi:type="varchar" name="sales_person_name" nullable="false" length="255" comment="Sales Person Name"/>
        <column xsi:type="varchar" name="sales_person_email" nullable="false" length="255" comment="Sales Person Email"/>
        <column xsi:type="varchar" name="customer_name" nullable="false" length="255" comment="Customer Name"/>
        <column xsi:type="varchar" name="priority" nullable="false" length="16" comment="Urgent/Regular"/>
        <column xsi:type="date" name="date_needed" nullable="false" comment="Date Art Needed"/>
        <column xsi:type="varchar" name="sportswear_type" nullable="true" length="64" comment="Type of Sportswear"/>
        <column xsi:type="varchar" name="product_other" nullable="true" length="255" comment="Other Requested Product"/>
        <column xsi:type="varchar" name="level" nullable="true" length="32" comment="Level"/>
        <column xsi:type="varchar" name="level_other" nullable="true" length="255" comment="Level Other (write-in)"/>
        <column xsi:type="varchar" name="logos_url" nullable="false" length="512" comment="Link to Logos"/>
        <column xsi:type="varchar" name="pantone_pref" nullable="true" length="255" comment="Pantone Colors Preference"/>
        <column xsi:type="varchar" name="design_style" nullable="false" length="16" comment="WILD/MODERATE/CONSERVATIVE"/>
        <column xsi:type="text"    name="comments" nullable="true" comment="Additional Comments"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="true" on_update="true" default="NULL" comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>

        <index referenceId="RSS_CUSTDESIGNS_EMAIL_IDX">
            <column name="sales_person_email"/>
        </index>
        <index referenceId="RSS_CUSTDESIGNS_DATE_NEEDED_IDX">
            <column name="date_needed"/>
        </index>
    </table>
</schema>
