<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
	<argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">events_grid.vns_events_grid_data_source</item>
            <item name="deps" xsi:type="string">events_grid.vns_events_grid_data_source</item>
        </item>
        <item name="spinner" xsi:type="string">event_columns</item>
        <item name="buttons" xsi:type="array">
            <item name="add" xsi:type="array">
                <item name="name" xsi:type="string">add</item>
                <item name="label" xsi:type="string" translate="true">Add Event</item>
                <item name="class" xsi:type="string">primary</item>
                <item name="url" xsi:type="url" path="events/event/add"/>
            </item>
        </item>
    </argument>
    <dataSource name="eventsGridDataSource">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider</argument>
            <argument name="name" xsi:type="string">vns_events_grid_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">event_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">event_id</item>
                    </item>
                </item>
            </argument>
        </argument>
    </dataSource>
    <paging name="listing_paging">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="storageConfig" xsi:type="array">
                    <item name="provider" xsi:type="string">events_grid.events_grid.listing_top.bookmarks</item>
                    <item name="namespace" xsi:type="string">current.paging</item>
                </item>
                <item name="selectProvider" xsi:type="string">events_grid.events_grid.event_columns.ids</item>
                <item name="displayArea" xsi:type="string">bottom</item>
            </item>
        </argument>
    </paging>
	<listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
    </listingToolbar>
    <columns name="event_columns">
    	<selectionsColumn name="ids">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="resizeEnabled" xsi:type="boolean">false</item>
                    <item name="resizeDefaultWidth" xsi:type="string">55</item>
                    <item name="indexField" xsi:type="string">event_id</item>
                </item>
            </argument>
        </selectionsColumn>
        <column name="event_id" sortOrder="10">
            <settings>
                <filter>text</filter>
                <sorting>asc</sorting>
                <label translate="true">Event ID</label>
            </settings>
        </column>
        <column name="name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Event Name</label>
            </settings>
        </column>
        <column name="image_url" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Image URL</label>
            </settings>
        </column>
        <column name="from_date" sortOrder="40">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Event Start Date</label>
            </settings>
        </column>
        <column name="to_date" sortOrder="50">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Event End Date</label>
            </settings>
        </column>
        <column name="location" sortOrder="60">
            <settings>
                <filter>text</filter>
                <label translate="true">Event Location</label>
            </settings>
        </column>
        <column name="age_range" sortOrder="70">
            <settings>
                <filter>text</filter>
                <label translate="true">Age Range</label>
            </settings>
        </column>
        <column name="type" sortOrder="80">
            <settings>
                <filter>text</filter>
                <label translate="true">Event Type</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="VNS\Events\Ui\Component\Listing\Column\EventActions">
            <settings>
                <indexField>event_id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>107</resizeDefaultWidth>
            </settings>
        </actionsColumn>
    </columns>
</listing>
